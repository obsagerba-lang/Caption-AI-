rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User display name
    //
    // Collection: favorites
    // Document ID: {captionId}
    // Fields:
    //   - id: string (required) - Unique ID
    //   - text: string (required) - Caption text
    //   - language: string (required) - Language
    //   - userId: string (required) - Owner UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "obsagerba@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /feedback/{feedbackId} {
      allow create: if isAuthenticated() && hasRequiredFields(['rating', 'comment', 'userId', 'createdAt']) && request.resource.data.userId == request.auth.uid && request.resource.data.rating is number && request.resource.data.rating >= 1 && request.resource.data.rating <= 5 && request.resource.data.comment is string && request.resource.data.comment.size() <= 1000;
      allow read: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'email']) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && request.resource.data.uid == userId;
      allow delete: if isOwner(userId);

      match /favorites/{captionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['id', 'text', 'language', 'userId']) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isOwner(userId);
      }

      match /drafts/{draftId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['id', 'userId', 'createdAt']) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isOwner(userId);
      }

      match /data/stats {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
  }
}
